print("\n" + "="*60)
print("Q1 – Descriptive & Inferential Statistics (Olympics)")
print("="*60)

col_names = ["Country","Games","Gold1","Silver1","Bronze1",
             "Gold2","Silver2","Bronze2","Gold3","Silver3",
             "Bronze3","Gold4","Silver4","Bronze4","Total","Combined"]

df_oly = pd.read_csv("olympics.csv", skiprows=2, header=None,
                     names=col_names)
df_oly = df_oly.dropna(subset=["Country"])

# Keep numeric medal columns
medal_cols = ["Gold1","Silver1","Bronze1","Total"]
df_oly[medal_cols] = df_oly[medal_cols].apply(pd.to_numeric, errors="coerce")
df_oly_num = df_oly[medal_cols].dropna()

print("\n── Descriptive Statistics ──")
desc = df_oly_num.describe()
print(desc)

print("\n── Mean ──\n", df_oly_num.mean())
print("\n── Median ──\n", df_oly_num.median())
print("\n── Std Dev ──\n", df_oly_num.std())
print("\n── Min ──\n", df_oly_num.min())
print("\n── Max ──\n", df_oly_num.max())

# Inferential – one-sample t-test: is mean Gold1 != 0?
t_stat, p_val = stats.ttest_1samp(df_oly_num["Gold1"].dropna(), 0)
print(f"\n── One-Sample t-test (Gold1 vs 0): t={t_stat:.3f}, p={p_val:.4f}")
print("  -> Mean Gold1 is significantly different from 0." if p_val < 0.05
      else "  -> Not significantly different from 0.")

# Correlation between Gold and Total
corr, p_c = stats.pearsonr(df_oly_num["Gold1"], df_oly_num["Total"])
print(f"\n── Pearson Correlation (Gold1 vs Total): r={corr:.3f}, p={p_c:.4f}")

# Inferences
print("""
── Inferences from Descriptive Statistics ──
1. The very high std-dev relative to the mean shows extreme spread –
   a few dominant nations win most medals while the majority win very few.
2. Median << Mean for 'Total', confirming right-skewed distribution.
3. Minimum = 0 across all medal types: many countries have never won a medal.
4. Strong Pearson correlation between Gold1 and Total confirms gold medals
   are the primary driver of the overall tally.
""")

fig, axes = plt.subplots(1, 2, figsize=(12, 4))
axes[0].bar(medal_cols, df_oly_num.mean(), color=["gold","silver","#cd7f32","steelblue"])
axes[0].set_title("Mean Medals per Category")
axes[0].set_ylabel("Mean Count")
axes[1].boxplot([df_oly_num[c].dropna() for c in medal_cols], labels=medal_cols)
axes[1].set_title("Boxplot of Medal Columns")
plt.tight_layout()
plt.savefig("/home/claude/q1_olympics_stats.png", dpi=100)
plt.close()
print("  [Plot saved: /home/claude/q1_olympics_stats.png]")
